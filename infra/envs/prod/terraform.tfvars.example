# Copy to terraform.tfvars (git-ignored) and fill with real values from the shared infra outputs.
# NOTE: no secrets here — batch_db_password_secret_arn is a *reference* to Secrets Manager,
# not the password itself (ADR-0003).

cost_center = "fin-reconciliation"

vpc_id                      = "vpc-0123456789abcdef0"
private_app_subnet_ids      = ["subnet-0aaa1111", "subnet-0bbb2222"]
data_tier_security_group_id = "sg-0rds00000000data0"
ecs_cluster_arn             = "arn:aws:ecs:eu-central-1:111122223333:cluster/contoso-prod"

batch_image = "111122223333.dkr.ecr.eu-central-1.amazonaws.com/contoso/batch:1.0.0"
rds_endpoint = "contoso-prod.abcdefghij.eu-central-1.rds.amazonaws.com"

batch_db_password_secret_arn = "arn:aws:secretsmanager:eu-central-1:111122223333:secret:contoso/prod/batch_db_password-AbCdEf"
