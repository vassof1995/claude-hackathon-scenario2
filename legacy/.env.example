# Legacy on-prem stack — local secrets. Copy to .env (git-ignored) and fill in.
# In the cloud target these become AWS Secrets Manager references.

# Postgres superuser (admin / migrations bootstrap)
POSTGRES_USER=contoso
POSTGRES_PASSWORD=change-me-admin
POSTGRES_DB=contoso

# Least-privilege application roles (created by reporting-db/init)
APP_DB_PASSWORD=change-me-app
BATCH_DB_PASSWORD=change-me-batch

# Read-only role the five reporting teams connect with
REPORT_DB_PASSWORD=change-me-report
